# Desk Command Center — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.

# === Google Calendar ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# === Microsoft 365 Calendar ===
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REFRESH_TOKEN=

# === Home Assistant ===
HA_URL=http://192.168.50.24:8123
HA_LONG_LIVED_TOKEN=

# === GitHub ===
GITHUB_TOKEN=

# === Supabase (Unfocused tasks) ===
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# === Monday.com ===
MONDAY_API_TOKEN=

# === Beads/Dolt ===
BEADS_DOLT_HOST=127.0.0.1
BEADS_DOLT_PORT=3310
BEADS_DOLT_USER=root
BEADS_DOLT_PASSWORD=
BEADS_DOLT_DATABASE=beads_DCC

# === Pi 5 ===
PI5_HOST=192.168.50.24
PI5_SSH_USER=strycher
PI5_SSH_PORT=22
